# =============================================================================
#  LOCAL credentials / overrides  -  TEMPLATE
#
#  HOW TO USE:
#    1. Copy this file to 'config.local.properties' (same folder).
#    2. Put your REAL values there.
#
#  'config.local.properties' is git-ignored and must NEVER be committed.
#  Values here override config.properties. JVM -D and environment variables
#  still take precedence over this file.
# =============================================================================

# Facebook account used by the test (a dedicated test account is recommended)
fb.username=your_facebook_email_or_phone
fb.password=your_facebook_password
